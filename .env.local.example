# ── Google Ads & Analytics ─────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the real IDs from your Google
# Ads / Analytics accounts, then restart `npm run dev`.

# Google Ads global site tag — ALSO powers remarketing/retargeting audiences.
# Find it in Google Ads → Tools → Conversions / Google tag. Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Conversion label for the "lead submitted" conversion action (the part after the
# slash in the conversion snippet, e.g. AW-123456789/AbC-D_efGh → AbC-D_efGh)
NEXT_PUBLIC_GADS_LEAD_LABEL=

# (Optional) GA4 measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# ── Live Google reviews (optional) ──────────────────────────────────────
# When both are set, the "Journeys They'll Never Forget" section shows live
# Google reviews (latest 5) + live rating, refreshed hourly. Without them it
# falls back to the curated real reviews.
#   1. Google Cloud Console → enable "Places API" → create an API key.
#   2. Get the Place ID from https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Lead delivery (optional) ────────────────────────────────────────────
# Where to forward captured leads. If unset, leads are appended to data/leads.jsonl.
# LEAD_WEBHOOK_URL=
